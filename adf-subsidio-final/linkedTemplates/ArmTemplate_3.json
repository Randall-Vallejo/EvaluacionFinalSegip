			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_bronze_spl_empleadores",
								"type": "DatasetReference"
							},
							"name": "source1"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_silver_spl_empleadores",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "derivedColumn1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          empleador_id as string,",
						"          nit as string,",
						"          razon_social as string,",
						"          tipo as string,",
						"          nro_patronal as string,",
						"          municipio as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> source1",
						"source1 derive(empleador_id = trim(empleador_id),",
						"          nit = trim(nit),",
						"          razon_social = trim(razon_social),",
						"          tipo = trim(tipo),",
						"          nro_patronal = trim(nro_patronal),",
						"          municipio = trim(municipio)) ~> derivedColumn1",
						"derivedColumn1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/df_silver_spl_entregas_agencia')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_bronze_spl_entregas_agencia",
								"type": "DatasetReference"
							},
							"name": "source1"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_silver_spl_entregas_agencia",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "derivedColumn1"
						},
						{
							"name": "derivedColumn2"
						},
						{
							"name": "filter1"
						},
						{
							"name": "derivedColumn3"
						}
					],
					"scriptLines": [
						"source(output(",
						"          entrega_ag_id as string,",
						"          asignacion_id as string,",
						"          ci_beneficiaria as string,",
						"          fecha_entrega as string,",
						"          productos as string,",
						"          lote as string,",
						"          peso_kg as string,",
						"          punto_entrega as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> source1",
						"source1 derive(entrega_ag_id = trim(entrega_ag_id),",
						"          asignacion_id = trim(asignacion_id),",
						"          ci_beneficiaria = trim(ci_beneficiaria),",
						"          fecha_entrega = trim(fecha_entrega),",
						"          productos = trim(productos),",
						"          lote = trim(lote),",
						"          peso_kg = trim(peso_kg),",
						"          punto_entrega = trim(punto_entrega)) ~> derivedColumn1",
						"derivedColumn1 derive(fecha_entrega = toString(toDate(fecha_entrega), 'dd/MM/yyyy')) ~> derivedColumn2",
						"derivedColumn2 filter(!isNull(asignacion_id)",
						"&& !isNull(ci_beneficiaria)",
						"&& !isNull(fecha_entrega)",
						"&& fecha_entrega != ''",
						"&& !isNull(productos)",
						"&& productos != ''",
						"&& !isNull(lote)",
						"&& lote != '') ~> filter1",
						"filter1 derive(punto_entrega = regexReplace(upper(trim(punto_entrega)), ' +', ' '),",
						"          productos = regexReplace(upper(trim(productos)), ' +', ' ')) ~> derivedColumn3",
						"derivedColumn3 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
