{
	"name": "df_silver_spl_certificados",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_spl_certificados",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_spl_certificados",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          certificado_id as string,",
				"          afiliacion_id as string,",
				"          fecha_emision as string,",
				"          semana_gestacion as string,",
				"          fecha_probable_parto as string,",
				"          medico_responsable as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(certificado_id = trim(certificado_id),",
				"          afiliacion_id = trim(afiliacion_id),",
				"          fecha_emision = trim(fecha_emision),",
				"          semana_gestacion = trim(semana_gestacion),",
				"          fecha_probable_parto = trim(fecha_probable_parto),",
				"          medico_responsable = trim(medico_responsable),",
				"          estado = trim(estado)) ~> derivedColumn1",
				"derivedColumn1 derive(fecha_probable_parto = toString(toDate(fecha_probable_parto), 'dd/MM/yyyy'),",
				"          fecha_emision = toString(toDate(fecha_emision), 'dd/MM/yyyy')) ~> derivedColumn2",
				"derivedColumn2 filter(!isNull(semana_gestacion)",
				"&& !isNull(fecha_probable_parto)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}