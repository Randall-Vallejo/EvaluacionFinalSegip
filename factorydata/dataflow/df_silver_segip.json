{
	"name": "df_silver_segip",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_segip",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CI as string,",
				"          Nombres as string,",
				"          {Ap. Paterno} as string,",
				"          {Ap. Materno} as string,",
				"          {Fecha Nac.} as string,",
				"          {Género} as string,",
				"          {Estado Civil} as string,",
				"          Municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(CI = trim(CI),",
				"          Nombres = trim(Nombres),",
				"          {Estado Civil} = trim({Estado Civil}),",
				"          {Ap. Paterno} = trim({Ap. Paterno}),",
				"          {Ap. Materno} = trim({Ap. Materno}),",
				"          {Fecha Nac.} = trim({Fecha Nac.}),",
				"          {Género} = trim({Género}),",
				"          Municipio = trim({Municipio})) ~> derivedColumn1"
			]
		}
	}
}