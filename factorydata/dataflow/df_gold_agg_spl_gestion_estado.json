{
	"name": "df_gold_agg_spl_gestion_estado",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_silver_spl_asignaciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gold_agg_spl_gestion_estado",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          asignacion_id as short,",
				"          afiliacion_id as short,",
				"          mes as short,",
				"          gestion as short,",
				"          monto_bs as double,",
				"          monto_productos as double,",
				"          monto_carnes as double,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 aggregate(groupBy(gestion,",
				"          estado),",
				"     cantidad_asignaciones = count(asignacion_id),",
				"          monto_total_bs = round(sum(toDouble(monto_bs)), 2),",
				"          monto_productos_total = round(sum(toDouble(monto_productos)), 2),",
				"          monto_carnes_total = round(sum(toDouble(monto_carnes)), 2)) ~> aggregate1",
				"aggregate1 select(mapColumn(",
				"          gestion,",
				"          estado,",
				"          cantidad_asignaciones,",
				"          monto_total_bs,",
				"          monto_productos_total,",
				"          monto_carnes_total",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}