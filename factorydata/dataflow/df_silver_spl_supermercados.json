{
	"name": "df_silver_spl_supermercados",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_spl_supermercados",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as string,",
				"          Cadena as string,",
				"          Sucursal as string,",
				"          Municipio as string,",
				"          {Dirección} as string,",
				"          Estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(ID = trim(ID),",
				"          Cadena = trim(Cadena),",
				"          Sucursal = trim(Sucursal),",
				"          Municipio = trim(Municipio),",
				"          {Dirección} = trim({Dirección}),",
				"          Estado = trim(Estado)) ~> derivedColumn1"
			]
		}
	}
}