{
	"name": "df_gold_dim_tiempo",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_silver_sup_controles",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gold_dim_tiempo",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_id as short,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as short,",
				"          nro_control as short,",
				"          fecha_control as string,",
				"          semana_gestacion as short,",
				"          peso_madre_kg as double,",
				"          presion_arterial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"derivedColumn1 select(mapColumn(",
				"          fecha,",
				"          anio,",
				"          mes,",
				"          dia,",
				"          trimestre",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn2 derive(fecha = toString(fecha_date, 'dd/MM/yyyy'),",
				"          anio = toInteger(toString(fecha_date, 'yyyy')),",
				"          mes = toInteger(toString(fecha_date, 'MM')),",
				"          dia = toInteger(toString(fecha_date, 'dd')),",
				"          trimestre = iif(     toInteger(toString(fecha_date, 'MM')) <= 3, 1,     iif(         toInteger(toString(fecha_date, 'MM')) <= 6, 2,         iif(             toInteger(toString(fecha_date, 'MM')) <= 9, 3, 4         )     ) )) ~> derivedColumn1",
				"source1 derive(fecha_date = toDate(fecha_control, 'dd/MM/yyyy')) ~> derivedColumn2",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}