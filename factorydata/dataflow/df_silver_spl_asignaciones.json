{
	"name": "df_silver_spl_asignaciones",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_spl_asignaciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          asignacion_id as string,",
				"          afiliacion_id as string,",
				"          mes as string,",
				"          gestion as string,",
				"          monto_bs as string,",
				"          monto_productos as string,",
				"          monto_carnes as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(asignacion_id = trim(asignacion_id),",
				"          afiliacion_id = trim(afiliacion_id),",
				"          mes = trim(mes),",
				"          gestion = trim(gestion),",
				"          monto_bs = trim(monto_bs),",
				"          monto_productos = trim(monto_productos),",
				"          monto_carnes = trim(monto_carnes),",
				"          estado = trim(estado)) ~> derivedColumn1"
			]
		}
	}
}