{
	"name": "df_silver_spl_afiliaciones",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_spl_afiliaciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_spl_afiliaciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          afiliacion_id as string,",
				"          ci_beneficiaria as string,",
				"          empleador_id as string,",
				"          caja_id as string,",
				"          fecha_afiliacion as string,",
				"          nro_matricula as string,",
				"          tipo_subsidio as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(ci_beneficiaria = trim(ci_beneficiaria),",
				"          afiliacion_id = trim(afiliacion_id),",
				"          empleador_id = trim(empleador_id),",
				"          caja_id = trim(caja_id),",
				"          fecha_afiliacion = trim(fecha_afiliacion),",
				"          nro_matricula = trim(nro_matricula),",
				"          tipo_subsidio = trim(tipo_subsidio),",
				"          estado = trim(estado)) ~> derivedColumn1",
				"derivedColumn1 derive(fecha_afiliacion = toString(toDate(fecha_afiliacion), 'dd/MM/yyyy')) ~> derivedColumn2",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}