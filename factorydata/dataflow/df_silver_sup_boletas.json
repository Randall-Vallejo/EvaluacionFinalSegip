{
	"name": "df_silver_sup_boletas",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_sup_boletas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_sup_boletas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(boleta_id = trim(boleta_id),",
				"          control_id = trim(control_id),",
				"          ci_beneficiaria = trim(ci_beneficiaria),",
				"          nro_boleta = trim(nro_boleta),",
				"          fecha_emision = trim(fecha_emision),",
				"          estado = trim(estado)) ~> derivedColumn1",
				"derivedColumn1 derive(fecha_emision = toString(     iif(         substring(replace(trim(fecha_emision), '/', '-'), 5, 1) == '-',         toDate(replace(trim(fecha_emision), '/', '-'), 'yyyy-MM-dd'),         toDate(replace(trim(fecha_emision), '/', '-'), 'dd-MM-yyyy')     ),     'dd/MM/yyyy' )) ~> derivedColumn2",
				"derivedColumn2 derive(estado = initCap(lower(trim(estado)))) ~> derivedColumn3",
				"derivedColumn3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}