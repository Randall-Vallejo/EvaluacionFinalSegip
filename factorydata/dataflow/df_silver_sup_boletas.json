				"          control_id = trim(control_id),",
				"          ci_beneficiaria = trim(ci_beneficiaria),",
				"          nro_boleta = trim(nro_boleta),",
				"          fecha_emision = trim(fecha_emision),",
				"          estado = trim(estado)) ~> derivedColumn1"
