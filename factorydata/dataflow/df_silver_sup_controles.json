{
	"name": "df_silver_sup_controles",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_sup_controles",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_sup_controles",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(control_id = trim(control_id),",
				"          ci_beneficiaria = trim(ci_beneficiaria),",
				"          establecimiento_id = trim(establecimiento_id),",
				"          nro_control = trim(nro_control),",
				"          fecha_control = trim(fecha_control),",
				"          semana_gestacion = trim(semana_gestacion),",
				"          peso_madre_kg = trim(peso_madre_kg),",
				"          presion_arterial = trim(presion_arterial)) ~> derivedColumn1",
				"derivedColumn1 derive(fecha_control = toString(     iif(         substring(replace(trim(fecha_control), '/', '-'), 5, 1) == '-',         toDate(replace(trim(fecha_control), '/', '-'), 'yyyy-MM-dd'),         toDate(replace(trim(fecha_control), '/', '-'), 'dd-MM-yyyy')     ),     'dd/MM/yyyy' )) ~> derivedColumn2",
				"derivedColumn2 filter(!isNull(presion_arterial) &&",
				"!isNull(fecha_control)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}