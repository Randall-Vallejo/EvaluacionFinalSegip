{
	"name": "df_silver_sup_entregas",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_sup_entregas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_silver_sup_entregas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as string,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as string,",
				"          fecha_proxima_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(entrega_id = trim(entrega_id),",
				"          boleta_id = trim(boleta_id),",
				"          ci_beneficiaria = trim(ci_beneficiaria),",
				"          establecimiento_id = trim(establecimiento_id),",
				"          paquete_id = trim(paquete_id),",
				"          paquete_nombre = trim(paquete_nombre),",
				"          fecha_entrega = trim(fecha_entrega),",
				"          lote_produccion = trim(lote_produccion),",
				"          peso_paquete_kg = trim(peso_paquete_kg),",
				"          fecha_proxima_entrega = trim(fecha_proxima_entrega)) ~> derivedColumn1",
				"derivedColumn1 derive(fecha_proxima_entrega = toString(     iif(         substring(replace(trim(fecha_proxima_entrega), '/', '-'), 5, 1) == '-',         toDate(replace(trim(fecha_proxima_entrega), '/', '-'), 'yyyy-MM-dd'),         toDate(replace(trim(fecha_proxima_entrega), '/', '-'), 'dd-MM-yyyy')     ),     'dd/MM/yyyy' ),",
				"          fecha_entrega = toString(     iif(         substring(replace(trim(fecha_entrega), '/', '-'), 5, 1) == '-',         toDate(replace(trim(fecha_entrega), '/', '-'), 'yyyy-MM-dd'),         toDate(replace(trim(fecha_entrega), '/', '-'), 'dd-MM-yyyy')     ),     'dd/MM/yyyy' )) ~> derivedColumn2",
				"derivedColumn2 filter(!isNull(lote_produccion)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}