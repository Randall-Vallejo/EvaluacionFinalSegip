{
	"name": "df_silver_sup_establecimientos",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_bronze_sup_establecimientos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(establecimiento_id = trim(establecimiento_id),",
				"          codigo_snis = trim(codigo_snis),",
				"          nombre = trim(nombre),",
				"          tipo = trim(tipo),",
				"          nivel_atencion = trim(nivel_atencion),",
				"          municipio = trim(municipio),",
				"          departamento = trim(departamento),",
				"          red_salud = trim(red_salud),",
				"          estado = trim(estado)) ~> derivedColumn1"
			]
		}
	}
}